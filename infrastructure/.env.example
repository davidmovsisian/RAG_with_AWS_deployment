# =============================================================================
# AWS Infrastructure Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then source it before running scripts:
#   source .env
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_PROFILE=default

# -----------------------------------------------------------------------------
# Project Configuration
# -----------------------------------------------------------------------------
# TEAM_NAME: Used as a suffix for all resource names. Use lowercase letters,
# numbers, and hyphens only (e.g. "team1", "alice", "group-a").
TEAM_NAME=team1
PROJECT_NAME=rag-class

# -----------------------------------------------------------------------------
# Resource Names (auto-generated from PROJECT_NAME and TEAM_NAME above)
# These are set by sourcing this file; do not change unless you know what
# you are doing.
# -----------------------------------------------------------------------------
S3_BUCKET=${PROJECT_NAME}-docs-${TEAM_NAME}
SQS_QUEUE_NAME=${PROJECT_NAME}-docs-queue-${TEAM_NAME}
IAM_ROLE_NAME=${PROJECT_NAME}-ec2-role-${TEAM_NAME}
IAM_INSTANCE_PROFILE=${PROJECT_NAME}-ec2-profile-${TEAM_NAME}
OPENSEARCH_DOMAIN=${PROJECT_NAME}-${TEAM_NAME}

# -----------------------------------------------------------------------------
# EC2 Configuration
# -----------------------------------------------------------------------------
EC2_INSTANCE_TYPE=t3.small

# The name of an existing EC2 key pair for SSH access.
# Create one in the AWS Console: EC2 → Key Pairs → Create key pair
EC2_KEY_NAME=your-ssh-key-name

# CIDR block for SSH access (default: open to all; restrict for security)
EC2_SSH_CIDR=0.0.0.0/0

# Ubuntu 22.04 LTS AMI (us-east-1). Update if using a different region.
# Find the latest AMI: aws ec2 describe-images --owners 099720109477 \
#   --filters "Name=name,Values=ubuntu/images/hvm-ssd/ubuntu-jammy-22.04-amd64-*"
EC2_AMI_ID=ami-0c7217cdde317cfec

# -----------------------------------------------------------------------------
# OpenSearch Configuration
# -----------------------------------------------------------------------------
OPENSEARCH_INSTANCE_TYPE=t3.small.search
OPENSEARCH_VOLUME_SIZE=10
