{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "OpenSearchHTTPAccess",
      "Effect": "Allow",
      "Action": [
        "es:ESHttpPost",
        "es:ESHttpPut",
        "es:ESHttpGet",
        "es:ESHttpDelete",
        "es:ESHttpHead",
        "es:ESHttpPatch"
      ],
      "Resource": "arn:aws:es:${AWS_REGION}:${ACCOUNT_ID}:domain/${OPENSEARCH_DOMAIN}/*"
    },
    {
      "Sid": "OpenSearchDescribeDomain",
      "Effect": "Allow",
      "Action": [
        "es:DescribeDomain",
        "es:DescribeDomains"
      ],
      "Resource": "arn:aws:es:${AWS_REGION}:${ACCOUNT_ID}:domain/${OPENSEARCH_DOMAIN}"
    }
  ]
}
