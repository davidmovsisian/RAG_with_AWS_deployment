# AWS Configuration
AWS_REGION=us-east-1
TEAM_NAME=davidm
PROJECT_NAME=rag-project2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ACCOUNT_ID=

# S3 Configuration
S3_BUCKET_NAME=${PROJECT_NAME}-docs-${TEAM_NAME}

# SQS Configuration
SQS_QUEUE_URL=https://sqs.${AWS_REGION}.amazonaws.com/{AWS_ACCOUNT_ID}/${PROJECT_NAME}-docs-queue-${TEAM_NAME}

# OpenSearch Configuration
OPENSEARCH_ENDPOINT=search-${PROJECT_NAME}-${TEAM_NAME}-krtoxdvag6v3ylpsgnl4qeapii.${AWS_REGION}.es.amazonaws.com
OPENSEARCH_INDEX_NAME=${PROJECT_NAME}-documents

# Google Gemini Configuration
Gemini_Api_Key=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=4096
GEMINI_TEMPERATURE=0.7
GEMINI_POOL_SIZE=2 # 1 thread per api and 1 threads per worker
EMBEDDING_DIMENSION=1536

# Chunking Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CHUNK_SIZE=1500

# API Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000
FLASK_HOST=0.0.0.0

# SQS Worker Configuration
WORKER_POLL_INTERVAL=5
WORKER_MAX_MESSAGES=10
WORKER_VISIBILITY_TIMEOUT=300

# RAG Configuration
RETRIEVAL_TOP_K=5
RERANK_ENABLED=false
RERANK_TOP_K=3

 # Gunicorn configuration
GUNICORN_WORKERS=1 # 1 worker with 1 threads to handle API requests
GUNICORN_THREADS=1
GUNICORN_WORKER_CLASS=gthread
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info