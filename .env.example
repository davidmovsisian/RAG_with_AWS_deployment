# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# S3 Configuration
S3_BUCKET_NAME=your-rag-documents-bucket
S3_PROCESSED_PREFIX=processed/
S3_FAILED_PREFIX=failed/

# SQS Configuration
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/your-queue-name

# OpenSearch Configuration
OPENSEARCH_ENDPOINT=https://your-opensearch-domain.us-east-1.es.amazonaws.com
OPENSEARCH_INDEX_NAME=rag-documents
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=your_password_here

# AWS Bedrock Configuration
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1
BEDROCK_LLM_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.7

# Chunking Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CHUNK_SIZE=1500

# API Configuration
FLASK_ENV=development
FLASK_DEBUG=True
API_PORT=5000
API_HOST=0.0.0.0

# Worker Configuration
WORKER_POLL_INTERVAL=5
WORKER_MAX_MESSAGES=10
WORKER_VISIBILITY_TIMEOUT=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# RAG Configuration
RETRIEVAL_TOP_K=5
RERANK_ENABLED=false
RERANK_TOP_K=3
